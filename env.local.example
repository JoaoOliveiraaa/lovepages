# Copie para .env.local (não commitar)
# Mesmo segredo da API (apps/api/.env) para o middleware validar o cookie lp_access_token
JWT_ACCESS_SECRET=cole-aqui-o-mesmo-valor-de-apps-api-JWT_ACCESS_SECRET-min-32-chars

# Durante UI sem integração de login, use true para não bloquear /app e /admin
LOVEPAGES_SKIP_AUTH_MIDDLEWARE=true
