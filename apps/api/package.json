{
  "name": "@lovepages/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "pnpm run build:domain && prisma generate && nest start --watch",
    "start": "node dist/main.js",
    "build:domain": "pnpm --filter @lovepages/domain build && pnpm --filter @lovepages/shared build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:init": "pnpm run build:domain && prisma generate && prisma migrate deploy && prisma db seed",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "system:check": "prisma generate && tsx scripts/system-check.ts",
    "db:up": "docker compose -f ../../infra/docker-compose.yml up -d",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@lovepages/domain": "workspace:*",
    "@lovepages/shared": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.3.1",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
