NODE_ENV=development
DATABASE_URL="file:./prisma/dev.db"
PORT=3001

# Obrigatórios (>=32). Valores de exemplo abaixo são considerados "fracos" até você
# definir ALLOW_INSECURE_DEV=true (somente desenvolvimento).
JWT_ACCESS_SECRET="troque-em-producao-access-min-32-chars!!"
JWT_REFRESH_SECRET="troque-em-producao-refresh-min-32-chars"
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800

ABACATE_WEBHOOK_SECRET="troque-webhook-secret-min-32-chars!!"

# Dev com segredos de exemplo: obrigatório true
ALLOW_INSECURE_DEV=true

# Opcional: rodar "prisma migrate deploy" antes de subir o servidor (CI/containers)
# RUN_MIGRATIONS_ON_BOOT=false

# Seed (opcional)
# SEED_ADMIN_EMAIL=admin@lovepages.local
# SEED_USER_EMAIL=user@lovepages.local
# SEED_ADMIN_PASSWORD=...
# SEED_USER_PASSWORD=...

# PostgreSQL (produção): ajuste schema.prisma provider + URL
# DATABASE_URL="postgresql://lovepages:lovepages@localhost:5432/lovepages"
